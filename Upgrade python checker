import getpass

special = "!@#$%^&*()_+-=[]{}|;:',.<>?/"

#your enter password does not see by anyone
password = getpass.getpass("Enter your password: ")

score = 0
missing = []

# Length Check
if len(password) >= 8:
    score += 1
else:
    missing.append("Password should be at least 8 characters long.")

# Uppercase Check
if any(ch.isupper() for ch in password):
    score += 1
else:
    missing.append("Add at least one uppercase letter (A-Z).")

# Lowercase Check
if any(ch.islower() for ch in password):
    score += 1
else:
    missing.append("Add at least one lowercase letter (a-z).")

# Digit Check
if any(ch.isdigit() for ch in password):
    score += 1
else:
    missing.append("Add at least one number (0-9).")

# Special Character Check
if any(ch in special for ch in password):
    score += 1
else:
    missing.append("Add at least one special character (!@#$%^&* etc.).")

# Space Check
if " " in password:
    print("\nPassword should not contain spaces.")

print("\nPassword Score:", score, "/ 5")

# Password Strength
if score <= 2:
    print("Password Strength : Weak")

elif score <= 4:
    print("Password Strength : Medium")

else:
    print("Password Strength : Strong")

# Suggestions
if missing:
    print("\nSuggestions to improve your password:")
    for i in missing:
        print("-", i)
else:
    print("\nExcellent! Your password meets all basic security requirements.")
